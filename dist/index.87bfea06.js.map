                "background-color": "rgba(25,25,25,1)"
            });
            $("svg").css({
                "width": "3.815rem"
            });
            $(".label-menu").css("top", "1.953rem");
        } else {
            $("header").css({
                "background-color": "rgba(0,0,0,0)",
                "transition": "all 0.25s ease-in"
            });
            $("svg").css({
                "width": "4.75rem",
                "transition": "all 0.25s ease-in",
                "display": "block"
            });
            $(".label-menu").css({
                "top": "1.953rem",
                "transition": "all 0.25s ease-in"
            });
        }
    });
    else if (startchange.length && window.matchMedia("(max-width: 767px)").matches) $(document).scroll(function() {
        scroll_start = $(this).scrollTop();
