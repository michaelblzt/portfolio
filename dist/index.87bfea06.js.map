            $("header").css({
                "background-color": "rgba(25,25,25,1)"
            });
            $("svg").css({
                "width": "3.052rem"
            });
            $(".label-menu").css("top", "1.953rem");
        } else {
            $("header").css({
                "background-color": "rgba(0,0,0,0)",
                "transition": "all 0.25s ease-in"
            });
            $(".label-menu").css("top", "1.953rem");
            $("svg").css({
                "width": "3.052rem",
                "transition": "all 0.25s ease-in"
            });
        }
    });
    else {
        $("header").css("background-color", "rgba(25,25,25,0)");
        $("svg").css({
            "width": "3.052rem",
            "display": "block"
        });
        $(".label-menu").css("top", "3.953rem");
    }
    // init AOS for front animation : fade-up, fade-down.... 
    AOS.init({
        easing: "ease-out-back",
        duration: 1000,
        disable: window.innerWidth < 1024
    });
    // init the loading bar
    $(window).load(function() {
        $("#preloader").fadeOut("slow", function() {
            $(this).remove();
        });
        NProgress.start();
        NProgress.done();
    });
    /* Every time the window is scrolled ... */ $(window).scroll(function() {
        /* Check the location of each desired element */ $(".hideme").each(function(i) {
            var bottom_of_object = $(this).offset().top;
            var bottom_of_window = $(window).scrollTop() + $(window).height();
            /* If the object is completely visible in the window, fade it it */ if (bottom_of_window > bottom_of_object) $(this).animate({
                "opacity": "1"
            }, 500);
        });
    });
});
