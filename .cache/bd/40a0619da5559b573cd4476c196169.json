56a4ea161f4c280.html\">Bio</a></li>\n\t\t\t<li><a href=\"/791968b089544b4b3dddf03e24c58236.html\" class=\"active\">Travaux</a></li>\n\t\t\t<li><a href=\"mailto:michael.blzt@gmail.com\">Contact</a></li>\n\t\t\t<li><a class=\"messenger-link\" href=\"https://www.messenger.com/t/mikeblaiz\" target=\"_blank\">&nbsp;</a></li>\n\t\t</ul>\n\t</div>\n\t\n\t<div class=\"nav-site--modif\" role=\"navigation\" data-aos=\"fade-down\">\n\t\t<input id=\"burger\" type=\"checkbox\">\n\n\t\t<label for=\"burger\" class=\"label-menu\"><!-- <em>Menu</em> -->\n\t\t    <span></span>\n\t\t    <span></span>\n\t\t    <span></span>\n\t\t</label>\n\n\t\t<nav>    \n\t\t\t<ul>\n\t\t\t\t<li><a href=\"/fb8a140d6f076647256a4ea161f4c280.html\">Bio</a></li>\n\t\t\t\t<li><a href=\"/791968b089544b4b3dddf03e24c58236.html\">Travaux</a></li>\n\t\t\t\t<li><a href=\"mailto:michael.blzt@gmail.com\">Contact</a></li>\n\t\t\t</ul>\n\n\t\t\t<div class=\"nav-site__social-list\"> \n\n\t\t\t\t<p> Ailleurs, sur les internets </p>\n\n\t\t\t\t<ul class=\"social-media-list\">\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://twitter.com/MichaelBlaizot\" target=\"_blank\" title=\"Profil Twitter\"><i class=\"fa fa-twitter\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://dribbble.com/MichaelBlaizot\" target=\"_blank\" title=\"Profil Pinterest\"><i class=\"fa fa-dribbble\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://medium.com/@michaelblaizot\" target=\"_blank\" title=\"Profil Medium\"><i class=\"fa fa-medium\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://www.linkedin.com/in/micha%C3%ABl-blaizot-882a3888?trk=hp-identity-name\" target=\"_blank\" title=\"Profil Linkedin\"><i class=\"fa fa-linkedin\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://www.instagram.com/mikblaiz/\" target=\"_blank\" title=\"Profil Instagram\"><i class=\"fa fa-instagram\"></i></a></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</nav>\n\t</div>\n\n\t\n\t\t\n</header>\n\n<!-- CONTENT GOES HERE -->\n\n<section id=\"pechavy-projet\" class=\"projets__wrapper section-wrapper--pbig start-change\">\n\t<div class=\"container--lg\">\n\t\t<h1 data-aos=\"fade-down\"><small>Téléshopping</small><br>Harmoniser la communication email du téléshopping, en rationnaliser l'approche design et permettre à la marque d'être plus efficiente</h1>\n\t\t<ul class=\"projet__tags\" data-aos=\"fade-up\">\n\t\t\t<li data-aos=\"fade-down\" data-aos-delay=\"100\"><small>Année</small><br><em>2019</em></li>\n\t\t\t<li data-aos=\"fade-down\" data-aos-delay=\"200\"><small>Agence</small><br><a class=\"link--light\" href=\"https://creads.org/\">Creads</a></li>\n\t\t\t<li data-aos=\"fade-down\" data-aos-delay=\"300\"><small>Compétence #1</small><br><em>UX Design</em></li>\n\t\t\t<li data-aos=\"fade-down\" data-aos-delay=\"400\"><small>Compétence #2</small><br><em>Product Design</em></li>\n\t\t\t<li data-aos=\"fade-down\" data-aos-delay=\"400\"><small>Compétence #3</small><br><em>Stratégie de communication</em></li>\n\t\t</ul>\n\t\t<figure class=\"projets__figure\" data-aos=\"fade-up\">\n\t\t\t<img src=\"/954bf035ed435b05c750021a766b1727.jpg\" alt=\"img - IMG TELESHOPPING\" class=\"lazyload\">\n\t\t\t  <figcaption>Newsletter du Téléshopping de TF1</figcaption>\n\t\t</figure>\n\t\t<div class=\"projets__paragraphe\" data-aos=\"fade-up\">\n\t\t\t<h2>Challenge</h2>\n\t\t\t<p>Avec plus de 30 ans d'existence dans le secteur du shopping télé, Téléshopping est le leader européen de l'activité. Leur demande était claire : les aider à simplifier leur communication, moderniser leur charte tout en faisant progresser le taux d'ouverture et de click sur l'email. Le choix a été porté sur la rationnalisation de leur communication en passant de 11 gabarits d'email différents à 4 pour favoriser l'harmonie de la marque et aider les clients à identifier d'un seul coup d'oeil les bonnes affaires présentes. La stratégie était double. Ramener de la cohérence dans la marque et accélérer l'élaboration des campagnes mails en laissant les clients se concentrer sur le discours plutôt que sur la forme de leur communication </p>\n\t\t</div>\n\t\t<figure class=\"projets__figure\" data-aos=\"fade-up\">\n\t\t\t<img src=\"/ab1e34ea45a8cfcd4c8bd288d5874c59.jpg\" alt=\"img - IMG TELESHOPPING\" class=\"lazyload\">\n\t\t\t<figcaption>Newsletter \"Multi-produits\"</figcaption>\n\t\t</figure>\n\t\t<figure class=\"projets__figure\" data-aos=\"fade-up\">\n\t\t\t<img src=\"/ab56550eddeb35659b16d072aab44816.jpg\" alt=\"img - Page granulés du site Pechavy Energies Alternatives\" class=\"lazyload\">\n\t\t\t  <figcaption>Newsletter \"Mono-produit\"</figcaption>\n\t\t</figure>\n\t\t<div class=\"projets__paragraphe\" data-aos=\"fade-up\">\n\t\t\t<h2>Réalisation</h2>\n\t\t\t<p>Aussi, au lieu de réaliser une direction artistique différente pour chaque email, le choix s'est porté sur la réalisation de template mail modulable et responsive, permettant aux clients de piocher dans un choix de blocks existants et ainsi composer eux-mêmes leurs mail transactionnel, newsletters tout en garantissant une délivérabilité optimale...<br> 2 types de communications ont été retenus : les coms dite \"évènementielle\" et les \"regular\". Cela permet aux clients de se projeter dans le type de message à faire passer, sélectionner le template idéal et commencer à composer leur texte.</p>\n\t\t</div>\n\t\t<figure class=\"projets__figure\" data-aos=\"fade-up\">\n\t\t\t<img src=\"/fc330062c2f8e7f0d3df0e455f8bbab8.jpg\" alt=\"img - Page commande du site Pechavy Energies Alternatives\" class=\"lazyload\">\n\t\t\t  <figcaption>Des blocks de contenu interchangeables et modulables</figcaption>\n\t\t</figure>\n\t\t<figure class=\"projets__figure\" data-aos=\"fade-up\">\n\t\t\t<img src=\"/47c291c91d100d1d18b1b53a3fea9f6d.jpg\" alt=\"img - Page récap de commande du site Pechavy Energies Alternatives\" class=\"lazyload\">\n\t\t\t  <figcaption>Newsletter \"Evènement\" avec produit </figcaption>\n\t\t</figure>\n\t\t<figure class=\"projets__figure\" data-aos=\"fade-up\">\n\t\t\t<img src=\"/b16b17d21a949aac927782866078d42c.jpg\" alt=\"img - Page connexion du site Pechavy Energies Alternatives\" class=\"lazyload\">\n\t\t\t  <figcaption>Newsletter \"Evènement\" sans produit</figcaption>\n\t\t</figure>\n\t</div>\n\t<div class=\"projet__navigation\" data-aos=\"fade-up\">\n\t\t<div class=\"container--lg\">\n\t\t\t<div class=\"projet__navigation__inside\">\n\t\t\t\t<a href=\"/92b8c755b26aa48801474dae7878cb37.html\" class=\"projet-navigation__link\">Précédent</a>\n\t\t\t\t<p>–</p>\n\t\t\t\t<a href=\"/a46d64016601472beb01c0797f0c0164.html\" class=\"projet-navigation__link nav--last\">Suivant</a>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>\n\n\n\n<!-- FIN CONTENT -->\n\n\n<!-- FOOTER -->\n<footer id=\"footer\" class=\"section-wrapper hideme\">\n\t<div class=\"container--lg\">\n \n\t\t<a href=\"mailto:michael.blzt@gmail.com\" title=\"Envoyer un email\">michael.blzt@gmail.com</a><br>\n\t\t<p>2019 - Tous droits réservés - Made with 🍺 + ❤️ </p><br>\n\n\t\t<ul class=\"social-media-list\">\n\t\t\t<li class=\"social-media-item\"><a href=\"https://twitter.com/MichaelBlaizot\" target=\"_blank\" title=\"Profil Twitter\"><i class=\"fa fa-twitter\"></i></a></li>\n\t\t\t<li class=\"social-media-item\"><a href=\"https://dribbble.com/MichaelBlaizot\" target=\"_blank\" title=\"Profil Pinterest\"><i class=\"fa fa-dribbble\"></i></a></li>\n\t\t\t<li class=\"social-media-item\"><a href=\"https://medium.com/@michaelblaizot\" target=\"_blank\" title=\"Profil Medium\"><i class=\"fa fa-medium\"></i></a></li>\n\t\t\t<li class=\"social-media-item\"><a href=\"https://www.linkedin.com/in/micha%C3%ABl-blaizot-882a3888?trk=hp-identity-name\" target=\"_blank\" title=\"Profil Linkedin\"><i class=\"fa fa-linkedin\"></i></a></li>\n\t\t\t<li class=\"social-media-item\"><a href=\"https://www.instagram.com/mikblaiz/\" target=\"_blank\" title=\"Profil Instagram\"><i class=\"fa fa-instagram\"></i></a></li>\n\t\t</ul>\n\n\t</div>\n\n</footer>\n<!-- FIN FOOTER -->\n\n<div class=\"colophon\">\n\t<p>Hey psssst... Si vous cherchez de talentueux développeurs pour votre prochain projet, n'hésitez pas à rendre visite à <a href=\"https://www.clement-andraud.com/\" target=\"_blank\"> Clément Andraud</a> et <a href=\"http://laurent-masforne.com/\" target=\"_blank\">Laurent Masforné</a>. Dites leur que vous venez de ma part :)</p>\n</div>\n\n<a href=\"#0\" class=\"cd-top js-cd-top\"></a>\n\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/2.1.4/jquery.min.js\"></script>\n<script src=\"https://cdn.rawgit.com/michalsnik/aos/2.1.1/dist/aos.js\"></script>\n<script src=\"/77ab163850ef0fa98d6a9ee9fb6bbcaf.js\"></script>\n\n\n\n</body>\n\n</html>"},"sourceMaps":null,"error":null,"hash":"19da9d014866bef022e9f68f65de8565","cacheData":{"env":{}}}