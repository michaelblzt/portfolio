ype=\"checkbox\">\n\n\t\t<label for=\"burger\" class=\"label-menu\"><!-- <em>Menu</em> -->\n\t\t    <span></span>\n\t\t    <span></span>\n\t\t    <span></span>\n\t\t</label>\n\n\t\t<nav>    \n\t\t\t<ul>\n\t\t\t\t<li class=\"active\"><a href=\"/fb8a140d6f076647256a4ea161f4c280.html\">Bio</a></li>\n\t\t\t\t<li><a href=\"/791968b089544b4b3dddf03e24c58236.html\">Travaux</a></li>\n\t\t\t\t<li><a href=\"mailto:m.blaizot@yahoo.fr\">Contact</a></li>\n\t\t\t</ul>\n\n\t\t\t<div class=\"nav-site__social-list\"> \n\n\t\t\t\t<p> Ailleurs, sur les internets </p>\n\n\t\t\t\t<ul class=\"social-media-list\">\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://twitter.com/MichaelBlaizot\" target=\"_blank\" title=\"Profil Twitter\"><i class=\"fa fa-twitter\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://dribbble.com/MichaelBlaizot\" target=\"_blank\" title=\"Profil Pinterest\"><i class=\"fa fa-dribbble\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://medium.com/@michaelblaizot\" target=\"_blank\" title=\"Profil Medium\"><i class=\"fa fa-medium\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://www.linkedin.com/in/micha%C3%ABl-blaizot-882a3888?trk=hp-identity-name\" target=\"_blank\" title=\"Profil Linkedin\"><i class=\"fa fa-linkedin\"></i></a></li>\n\t\t\t\t\t<li class=\"social-media-item\"><a href=\"https://www.instagram.com/mikblaiz/\" target=\"_blank\" title=\"Profil Instagram\"><i class=\"fa fa-instagram\"></i></a></li>\n\t\t\t\t</ul>\n\t\t\t</div>\n\t\t</nav>\n\t</div>\n\t\t\n</header>\n\n<!-- CONTENT GOES HERE -->\n<div id=\"wrapper__about\">\n\t<section class=\"mastahead mastahead__about\" data-aos=\"fade-down\">\n\t\t<article class=\"container--lg\">\n\t\t\t<h1>Michaël Blaizot</h1>\n\t\t\t<h2 class=\"work-sector\"> Product designer freelance</h2>\n\t\t\t<p> Je m'applique à placer <strong>l'humain au coeur de toutes mes réflexions</strong> et de tous mes travaux de design. Je tente toujours de <em>comprendre</em> &amp; de <em>mixer les impératifs commerciaux face aux attentes des utilisateurs</em> pour créer l'alchimie <em>d'une expérience digitale réussie, fonctionnelle &amp; agréable à utiliser.</em></p>\n\t\t\t<a class=\"button button--small button--black button--margin-bottom\" href=\"/9e0c1a4a833302896248ee1438616c3d.pdf\"> Télécharger mon CV</a>\n\t\t\t<a class=\"button button--small button--yellow\" href=\"https://www.malt.fr/profile/michaelblaizot\"> Me proposer un projet</a>\n\t\t<!-- <div class=\"filet-head\">&nbsp;</div> -->\n\t\t</article>\n\t</section>\n\t<section class=\"section-wrapper presentation-wrapper start-change\">\n\t\t<div class=\"container--lg\">\n\t\t\t<div class=\"wrapper-title\" data-aos=\"fade-down\">\n\t\t\t\t<h2>En bref</h2>\n\t\t\t\t<p>Quelques lignes de présentation</p>\n\t\t\t</div>\n\t\t</div>\n\t\t<article class=\"content-block__wrapper\">\n\t\t\t<div class=\"container--lg\">\n\t\t\t\t<div class=\"content-block__container presentation-block\">\n\t\t\t\t\t<div class=\"img-container\" data-aos=\"fade-up\">\n\t\t\t\t\t\t<img src=\"/05f9b71a4a10f358748dd8ec99395866.jpg\" alt=\"Image NATURAMIND presentation\">\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"txt-container\" data-aos=\"fade-up\">\n\t\t\t\t\t\t<small>Hello ! </small>\n\t\t\t\t\t\t<h3><em>Autodidacte</em>, <em>30 ans</em>, <em>guitariste</em>, amateur de <em>bières fraiches</em>, de <em>randonnées</em> et de <em>lettering</em>.</h3>\n\t\t\t\t\t\t<p>Auparavant journaliste, j'ai 10 ans d'expérience dans les métiers du digital tant dans la conception de page, la rédaction de contenu, l'animation de communauté que dans l'élaboration de stratégie de communication engageante. </p>\n\t\t\t\t\t\t<a class=\"button button--small button--black\" href=\"/791968b089544b4b3dddf03e24c58236.html\">Découvrir mes travaux</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</article>\n\t</section>\n\t<section class=\"section-wrapper client-wrapper\">\n\t\t<div class=\"conta